{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "next dev",
    "gga:run": "bash -lc 'command -v gga >/dev/null 2>&1 || { echo \"Falta gga en PATH (instalación global requerida).\"; exit 1; }; gga run'",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "build": "next build",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/styles/**/*.scss\"",
    "typecheck": "tsc -b",
    "test": "vitest",
    "analyze:bundle": "ANALYZE=true pnpm build",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "audit:prod": "pnpm audit --prod",
    "check:local": "pnpm run test:run && pnpm run lint && pnpm run build",
    "check:preprod": "pnpm run test:run && pnpm run lint && pnpm run build && pnpm run audit:prod",
    "cleanup:repos": "bash scripts/cleanup-repos.sh",
    "cleanup:repos:dry-run": "bash scripts/cleanup-repos.sh --dry-run",
    "resize-profile": "node scripts/resize-profile-photo.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "gga:install": "gga install",
    "gga:pr": "gga run --pr-mode",
    "ollama:serve": "ollama serve",
    "ollama:pull": "ollama pull qwen2.5-coder:7b"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^15.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "postcss-scss": "^4.0.9",
    "puppeteer-core": "^24.43.1",
    "sass": "^1.101.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
